# ─────────────────────────────────────────
# Database (PostgreSQL via Docker)
# ─────────────────────────────────────────
DATABASE_URL=postgresql://outreachai:outreachai_dev@localhost:5432/outreachai

# ─────────────────────────────────────────
# Authentication (better-auth)
# ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_with_random_secret_string
BETTER_AUTH_URL=https://outreachai-gamma.vercel.app

# ─────────────────────────────────────────
# Lead Scraping (Apify)
# https://apify.com → Settings → Integrations
# ─────────────────────────────────────────
APIFY_TOKEN=your_apify_token_here

# ─────────────────────────────────────────
# AI Email Generation (OpenAI)
# https://platform.openai.com → API keys
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────
# Payments (Stripe)
# https://dashboard.stripe.com → Developers → API keys
# Use test keys (sk_test_ / pk_test_) for development
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_URL=https://outreachai-gamma.vercel.app
